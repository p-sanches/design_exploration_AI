# This file is only for frontend-visible (VITE_*) build-time variables.
# The Claude API key lives in .dev.vars (local) or Cloudflare Pages env (prod),
# NOT here — it must never ship in the browser bundle.

# Optional: if you set a workshop code on the proxy, also set it here so the
# frontend sends the matching X-Workshop-Code header.
# VITE_WORKSHOP_CODE=your-code
